# Copy this to .env and fill in your values

# Grok (xAI) LLM — get your key at console.x.ai
XAI_API_KEY=your-xai-api-key-here
XAI_MODEL=grok-3-latest

APP_NAME="PDF Data Extractor"
APP_VERSION="1.0.0"
DEBUG=false

# MySQL connection string (aiomysql driver)
DATABASE_URL=mysql+aiomysql://root:@localhost:3306/dataextractor

# Directory for temporary PDF uploads (auto-cleaned after processing)
UPLOAD_DIR=/tmp/pdf_uploads

# Maximum PDF file size in megabytes
MAX_FILE_SIZE_MB=50

# Path to the Tesseract binary (for OCR on scanned PDFs)
# Linux default: /usr/bin/tesseract
# macOS Homebrew: /opt/homebrew/bin/tesseract
TESSERACT_CMD=/usr/bin/tesseract
